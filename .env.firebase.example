# Optional Firebase Hosting deployment for the React web assets.
# Copy to .env.firebase.<env>, for example .env.firebase.staging.

DEPLOY_ENV=staging
FIREBASE_PROJECT_ID=your-gcp-project-id
FIREBASE_HOSTING_SITE_ID=community-kitchen-staging-assets
# Must match the target in firebase.json unless you intentionally edit both.
FIREBASE_HOSTING_TARGET=web-assets

# Makes the Apps Script build emit a small shell that loads the hashed JS from Firebase Hosting.
CK_WEB_ASSET_MODE=external
CK_WEB_ASSET_BASE_URL=https://community-kitchen-staging-assets.web.app
