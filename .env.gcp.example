# Local GCP backend settings for Cloud Run + Firestore.
# Copy to .env.gcp (or .env.gcp.staging / .env.gcp.prod) and update values.

# Optional: environment name (staging | prod)
DEPLOY_ENV=staging

# Required: Google Cloud project id
GCP_PROJECT_ID=""

# Required: Cloud Run region
GCP_REGION="europe-west1"

# Required: Firestore database id
GCP_FIRESTORE_DATABASE="(default)"

# Required: Firestore location (regional or multi-region)
GCP_FIRESTORE_LOCATION="eur3"

# Required: Cloud Run service name
GCP_CLOUD_RUN_SERVICE="community-kitchen-api-staging"

# Optional: source directory to deploy with gcloud --source
GCP_CLOUD_RUN_SOURCE_DIR="cloud-run/api"

# Required: runtime service account id (email is derived from project id)
GCP_RUNTIME_SERVICE_ACCOUNT_ID="community-kitchen-api-staging"

# Optional: allow unauthenticated access to Cloud Run
GCP_ALLOW_UNAUTHENTICATED=1

# Optional: backend providers used by the Cloud Run API.
# drive = read existing Google Sheets / Google Drive through Google APIs.
# firestore = read operational data from Firestore.
CK_DATA_BACKEND="drive"
CK_FILE_BACKEND="drive"

# Required for CK_DATA_BACKEND=drive when data source configs reference tabs
# in the active spreadsheet by name rather than by an explicit sheetId::tabName.
CK_DEFAULT_SPREADSHEET_ID=""

# Optional: default Shared Drive folder for Cloud Run uploads when a FILE_UPLOAD
# field does not configure uploadConfig.destinationFolderId. Service accounts do
# not have My Drive storage quota, so Cloud Run uploads require a Shared Drive
# folder shared with the runtime service account. Otherwise keep upload writes on
# Apps Script.
CK_UPLOAD_FOLDER_ID=""

# Optional: default Shared Drive folder for queued analytics XLSX exports when a
# pipeline does not define attachment.folderId.
CK_ANALYTICS_EXPORT_FOLDER_ID=""

# Optional: HMAC secret for stateless Cloud Run preview cleanup tokens. Set this
# when renderDocTemplateHtml/renderSubmissionReportHtml are routed to Cloud Run
# and the service may run with more than one instance.
CK_PREVIEW_CLEANUP_SECRET=""

# Optional: shared secret for Cloud Scheduler / cron calls to
# POST /api/jobs/runQueuedAnalyticsPipelineJobs,
# POST /api/jobs/runDailyAnalyticsRecompute, and
# POST /api/jobs/runDailyLifecycleRecompute.
CK_SCHEDULER_SECRET=""

# Optional: max queued analytics export jobs processed per scheduler run.
CK_ANALYTICS_QUEUE_BATCH_SIZE=10

# Optional: Cloud Scheduler cron schedules. Defaults mirror the Apps Script
# daily jobs and poll queued exports every 5 minutes.
CK_TIMEZONE="Europe/Brussels"
CK_SCHEDULER_QUEUE_SCHEDULE="*/5 * * * *"
CK_SCHEDULER_ANALYTICS_SCHEDULE="0 23 * * *"
CK_SCHEDULER_LIFECYCLE_SCHEDULE="0 2 * * *"

# Optional: Gmail API delegation for Cloud Run SEND_EMAIL follow-up actions.
# The runtime service account must have Google Workspace domain-wide delegation
# for https://www.googleapis.com/auth/gmail.send, and the delegated user must be
# allowed to send as the configured followupConfig.emailFrom address/alias.
CK_GMAIL_DELEGATED_USER="operations@example.org"

# Optional override when the delegated Gmail service account is not the runtime
# service account derived from GCP_RUNTIME_SERVICE_ACCOUNT_ID + GCP_PROJECT_ID.
CK_GMAIL_SERVICE_ACCOUNT_EMAIL=""

# Optional Gmail API user id. "me" resolves to CK_GMAIL_DELEGATED_USER.
CK_GMAIL_USER_ID="me"

# Optional: JSON RPC body limit in MiB. Upload payloads are base64 encoded.
CK_API_RPC_MAX_BODY_MB=25

# Optional: restrict browser CORS for the Cloud Run API.
# CK_API_CORS_ORIGIN="https://script.google.com"
