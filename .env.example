# Local config for scripts/export-form-config.js
# Copy to .env (or .env.staging / .env.prod) and update values.

# Apps Script web app URL (use /exec deployment)
CK_APP_URL="https://script.google.com/macros/s/<deployment-id>/exec"

# Form key (config sheet name or form title)
CK_FORM_KEY="Config: Meal Production"

# Optional output path (file or folder)
# CK_EXPORT_OUT="docs/config/exports/meal_production.json"

# Optional: config environment for bundled exports (staging | prod)
# CK_CONFIG_ENV=staging

# Local config for Playwright E2E runs
# E2E_BASE_URL="https://script.google.com/macros/s/<deployment-id>/exec"
# E2E_FORM_KEY_MEAL_PRODUCTION="Config: Meal Production"
# E2E_PROJECT=chromium-mobile
# E2E_CAPTURE_SUCCESS_ARTIFACTS=1
# E2E_HEADLESS=1
